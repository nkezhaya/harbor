<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50 dark:bg-gray-950">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Admin · Harbor" suffix="">
      {assigns[:page_title]}
    </.live_title>
    <link rel="stylesheet" href={asset_path(@conn, :css)} />
    <script defer type="module" src={asset_path(@conn, :js)}>
    </script>
  </head>
  <body class="min-h-full antialiased">
    {@inner_content}
  </body>
</html>
